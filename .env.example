# ============================================================
# RWA Ops Monitoring — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your credentials.
# NEVER commit your populated .env file to version control.
# .env is already excluded in .gitignore.
# ============================================================

# --- Alchemy (Ethereum + Base RPC endpoints) ---
# Get from: https://dashboard.alchemy.com
ALCHEMY_ETH_URL=
ALCHEMY_BASE_URL=

# --- Etherscan API ---
# Get from: https://etherscan.io/myapikey
ETHERSCAN_API_KEY=

# --- Anthropic / Claude API ---
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=

# --- Telegram Bot ---
# Create via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Midas bot polling frequency ---
POLL_INTERVAL_SECONDS=60

# --- Centrifuge pool IDs ---
# JTRSY pool: 281474976710662
# JAAA pool:  281474976710663
POOL_ID=